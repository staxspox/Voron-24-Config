[gcode_macro MEASURE_NOZZLE_Z_THERMAL_COEFF]
description: Pomiar zmiany Z w funkcji temperatury dyszy - Beacon Contact + homing + QGL
gcode:
    {% set VERBOSE = params.VERBOSE|default(0)|int %}
    {% set MIN_TEMP = params.MIN_TEMP|default(140)|int %}
    {% set MAX_TEMP = params.MAX_TEMP|default(290)|int %}
    {% set INTERVAL = params.INTERVAL|default(10)|int %}
    {% set SOAK_TIME  = params.SOAK_TIME|default(45)|float * 1000 %}
    {% set SAMPLES    = params.SAMPLES|default(3)|int %}
    {% set APPROACH_SPEED_MM_S   = params.APPROACH_SPEED|default(4.0)|float %}
    {% set LIFT_SPEED_MM_S       = params.LIFT_SPEED|default(15)|float %}
    {% set FAST_APPROACH_SPEED_MM_S = params.FAST_APPROACH_SPEED|default(10)|float %}
    {% set SAFE_LIFT_HEIGHT      = params.LIFT_HEIGHT|default(15)|float %}
    {% set PRE_PROBE_HEIGHT      = params.PRE_PROBE_HEIGHT|default(5)|float %}

    {% set APPROACH_SPEED = APPROACH_SPEED_MM_S * 60 %}
    {% set LIFT_SPEED     = LIFT_SPEED_MM_S * 60 %}
    {% set FAST_APPROACH  = FAST_APPROACH_SPEED_MM_S * 60 %}

    {% set temperatures = [] %}
    {% set z_readings   = [] %}

    {action_respond_info("=== Pomiar rozszerzalności termicznej dyszy (Beacon Contact) ===")}
    {action_respond_info(" Zakres: %d → %d °C   krok %d °C   prędkość: %.1f mm/s   samples: %d" % (MIN_TEMP, MAX_TEMP, INTERVAL, APPROACH_SPEED_MM_S, SAMPLES))}

    {% if printer.toolhead.homed_axes != "xyz" %}
        {action_respond_info("Homing wszystkich osi...")}
        G28
    {% else %}
        {action_respond_info("Osie już zahomowane")}
    {% endif %}

    {% if printer.quad_gantry_level is defined and (printer.quad_gantry_level.applied is not defined or not printer.quad_gantry_level.applied) %}
        {action_respond_info("QUAD_GANTRY_LEVEL – robię...")}
        QUAD_GANTRY_LEVEL
        G28 Z
    {% else %}
        {action_respond_info("QGL już zrobiony – pomijam")}
    {% endif %}

    G1 Z{SAFE_LIFT_HEIGHT} F{LIFT_SPEED * 1.5}

    # ─── Pętla w górę ───────────────────────────────────────────────────────────────
    {% for temp in range(MIN_TEMP, MAX_TEMP + 1, INTERVAL) %}
        M109 S{temp}
        G4 P{SOAK_TIME|int}
        {% if VERBOSE or (temp % 50 == 0) %}
            {action_respond_info("Postęp ↑ %d °C" % temp)}
        {% endif %}

        G1 Z{SAFE_LIFT_HEIGHT} F{LIFT_SPEED}
        G1 Z{PRE_PROBE_HEIGHT} F{FAST_APPROACH}
        M400
        G1 E-1.0 F1800

        BEACON_POKE SAMPLES={SAMPLES} SAMPLES_RESULT=median SAMPLES_TOLERANCE=0.020 SAMPLES_TOLERANCE_RETRIES=5 SPEED={APPROACH_SPEED_MM_S}

        G1 E-0.2 F1800
        G1 E0.2 F1800
        M400

        {% set z = printer.toolhead.position.z | float(0.0) %}
        {% set _ = temperatures.append(temp) %}
        {% set _ = z_readings.append(z) %}

        {% if VERBOSE %}
            {action_respond_info(" T=%d °C   Z=%.6f" % (temp, z))}
        {% endif %}
    {% endfor %}

    # ─── Pętla w dół ────────────────────────────────────────────────────────────────
    {action_respond_info("Pomiar w dół: %d → %d °C   krok %d °C" % (MAX_TEMP, MIN_TEMP, INTERVAL))}

    {% for temp in range(MAX_TEMP, MIN_TEMP - 1, -INTERVAL) %}
        M109 S{temp}
        G4 P{SOAK_TIME|int}
        {% if VERBOSE or (temp % 50 == 0) %}
            {action_respond_info("Postęp ↓ %d °C" % temp)}
        {% endif %}

        G1 Z{SAFE_LIFT_HEIGHT} F{LIFT_SPEED}
        G1 Z{PRE_PROBE_HEIGHT} F{FAST_APPROACH}
        M400
        G1 E-1.0 F1800

        BEACON_POKE SAMPLES={SAMPLES} SAMPLES_RESULT=median SAMPLES_TOLERANCE=0.020 SAMPLES_TOLERANCE_RETRIES=5 SPEED={APPROACH_SPEED_MM_S}

        G1 E-0.2 F1800
        G1 E0.2 F1800
        M400

        {% set z = printer.toolhead.position.z | float(0.0) %}
        {% set _ = temperatures.append(temp) %}
        {% set _ = z_readings.append(z) %}

        {% if VERBOSE %}
            {action_respond_info(" T=%d °C   Z=%.6f" % (temp, z))}
        {% endif %}
    {% endfor %}

    M104 S0
    {action_respond_info("Pomiar zakończony – grzałka wyłączona")}

    # ─── Regresja liniowa ───────────────────────────────────────────────────────────
    {% if z_readings|length < 4 %}
        {action_respond_info("ZA MAŁO PUNKTÓW – minimum 4 wymagane")}
    {% else %}
        {% set n = z_readings|length %}
        {% set sum_t = temperatures|sum %}
        {% set sum_z = z_readings|sum %}
        {% set avg_t = sum_t / n %}
        {% set avg_z = sum_z / n %}

        {% set sum_num = namespace(s=0.0) %}
        {% set sum_den = namespace(s=0.0) %}

        {% for i in range(n) %}
            {% set dt = temperatures[i] - avg_t %}
            {% set dz = z_readings[i] - avg_z %}
            {% set sum_num.s = sum_num.s + (dt * dz) %}
            {% set sum_den.s = sum_den.s + (dt * dt) %}
        {% endfor %}

        {% set slope = sum_num.s / sum_den.s if sum_den.s != 0 else 0.0 %}
        {% set coeff = (-slope * 1000) | round(4) %}

        {action_respond_info("────────────────────────────────────────────")}
        {action_respond_info(" ΔZ / ΔT     = %.6f mm/°C" % slope)}
        {action_respond_info(" Współczynnik = %.4f µm/°C" % coeff)}
        {action_respond_info(" Punkty: %d" % n)}
        {action_respond_info("────────────────────────────────────────────")}
        {action_respond_info("Sugerowana wartość:   temp_coeff: %.4f" % coeff)}
        {action_respond_info(" (negacja jeśli kompensujesz wydłużanie dyszy)")}
    {% endif %}